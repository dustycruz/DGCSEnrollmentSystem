@* File: EnrollmentSystem.UI/Views/Account/ChangePassword.cshtml *@
@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo"><img src="/images/logo.png" alt="DGCS" /></div>
        <div class="auth-title">Change Your Password</div>
        <div class="auth-sub">For your security, please set a new password.</div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="@(ViewData.ModelState.ErrorCount > 0 ? "" : "display:none")"></div>

        <form asp-action="ChangePassword" method="post">
            <div class="mb-3">
                <label class="form-label" asp-for="CurrentPassword"></label>
                <input class="form-control" asp-for="CurrentPassword" type="password" placeholder="Your current / temporary password" autofocus />
                <span asp-validation-for="CurrentPassword" class="text-validation"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="NewPassword"></label>
                <input class="form-control" asp-for="NewPassword" type="password" placeholder="At least 6 characters" />
                <span asp-validation-for="NewPassword" class="text-validation"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="ConfirmPassword"></label>
                <input class="form-control" asp-for="ConfirmPassword" type="password" placeholder="Re-enter new password" />
                <span asp-validation-for="ConfirmPassword" class="text-validation"></span>
            </div>
            <button type="submit" class="btn btn-brand w-100">Update Password</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}