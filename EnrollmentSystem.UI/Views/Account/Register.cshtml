@* File: EnrollmentSystem.UI/Views/Account/Register.cshtml *@
@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo"><img src="/images/logo.png" alt="DGCS" /></div>
        <div class="auth-title">Create Account</div>
        <div class="auth-sub">Register as an applicant</div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="@(ViewData.ModelState.ErrorCount > 0 ? "" : "display:none")"></div>

            <div class="mb-3">
                <label class="form-label" asp-for="UserName"></label>
                <input class="form-control" asp-for="UserName" placeholder="Choose a username" />
                <span asp-validation-for="UserName" class="text-validation"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Email"></label>
                <input class="form-control" asp-for="Email" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-validation"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Password"></label>
                <input class="form-control" asp-for="Password" type="password" placeholder="At least 6 characters" />
                <span asp-validation-for="Password" class="text-validation"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="ConfirmPassword"></label>
                <input class="form-control" asp-for="ConfirmPassword" type="password" placeholder="Re-enter password" />
                <span asp-validation-for="ConfirmPassword" class="text-validation"></span>
            </div>

            <button type="submit" class="btn btn-brand w-100">Create Account</button>
        </form>

        <p class="text-center mt-3" style="font-size:14px;">
            Already registered? <a asp-action="Login">Sign in</a>
        </p>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}