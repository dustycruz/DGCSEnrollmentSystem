@* File: EnrollmentSystem.UI/Views/Teacher/Advisory.cshtml *@
@model IEnumerable<Section>
@{
    ViewData["Title"] = "My Advisory";
}
<h1 class="page-title">My Advisory Class</h1>
<p class="page-subtitle">Sections where you are the assigned class adviser. Click a row to view its class list.</p>

<div class="content-card">
    @if (Model.Any())
    {
        <table class="table">
            <thead><tr><th>Section</th><th>Grade Level</th><th>School Year</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr data-href="@Url.Action("ClassList", "Teacher", new { sectionId = s.SectionId })">
                        <td><strong>@s.Name</strong></td>
                        <td>@(s.GradeLevel?.Name ?? "-")</td>
                        <td>@(s.SchoolYear?.Name ?? "-")</td>
                        <td style="text-align:right;color:var(--muted);"><i data-lucide="chevron-right"></i></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state"><i data-lucide="user-x"></i><p>You are not assigned as adviser to any section.</p></div>
    }
</div>
@section Scripts {
    <script>if (window.lucide) lucide.createIcons();</script>
}