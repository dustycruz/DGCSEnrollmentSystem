@* File: EnrollmentSystem.UI/Views/Teacher/EncodeGrades.cshtml *@
@model GradeEncodeViewModel
@{
    ViewData["Title"] = "Encode Grades";
}
<h1 class="page-title">Encode Grades</h1>
<p class="page-subtitle">@Model.SubjectName · @Model.SectionName</p>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<div class="content-card">
    <div style="display:flex;gap:8px;margin-bottom:14px;">
        @foreach (var q in new[] { "Q1", "Q2", "Q3", "Q4" })
        {
            <a class="btn @(q == Model.Quarter ? "btn-brand" : "btn-outline-brand")" style="padding:6px 16px;font-size:13px;"
               asp-action="EncodeGrades" asp-route-scheduleId="@Model.ScheduleId" asp-route-quarter="@q">@q</a>
        }
    </div>

    <form asp-action="EncodeGrades" method="post">
        <input type="hidden" asp-for="ScheduleId" />
        <input type="hidden" asp-for="SectionId" />
        <input type="hidden" asp-for="SubjectId" />
        <input type="hidden" asp-for="GradeLevelId" />
        <input type="hidden" asp-for="TeacherId" />
        <input type="hidden" asp-for="SectionName" />
        <input type="hidden" asp-for="SubjectName" />
        <input type="hidden" asp-for="Quarter" />

        @if (Model.Rows.Any())
        {
            <table class="table">
                <thead><tr><th>Student</th><th style="width:160px;">Grade (@Model.Quarter)</th></tr></thead>
                <tbody>
                    @for (var i = 0; i < Model.Rows.Count; i++)
                    {
                        <tr>
                            <td>
                                @Model.Rows[i].StudentName
                                <input type="hidden" asp-for="Rows[i].StudentId" />
                                <input type="hidden" asp-for="Rows[i].StudentName" />
                            </td>
                            <td><input class="form-control" asp-for="Rows[i].Grade" type="number" step="0.01" min="0" max="100" placeholder="0-100" /></td>
                        </tr>
                    }
                </tbody>
            </table>
            <button type="submit" class="btn btn-brand">Save Grades</button>
        }
        else
        {
            <p style="color:var(--muted)">No enrolled students in this section yet.</p>
        }
    </form>
</div>
<a class="btn btn-outline-brand" asp-action="Index">Back to My Classes</a>