@* File: EnrollmentSystem.UI/Views/Apply/Verify.cshtml *@
@model OtpViewModel
@{
    ViewData["Title"] = "Verify Email";
    Layout = "_Layout";
    var demoCode = ViewData["DemoCode"] as string;
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo"><img src="/images/logo.png" alt="DGCS" /></div>
        <div class="auth-title">Verify Your Email</div>
        <div class="auth-sub">Step 2 — Enter the code sent to <strong>@Model.Email</strong></div>

        <div class="steps">
            <div class="step done"><span class="dot">✓</span> Email</div>
            <div class="step active"><span class="dot">2</span> Verify</div>
            <div class="step"><span class="dot">3</span> Password</div>
        </div>

        @if (!string.IsNullOrEmpty(demoCode))
        {
            <div class="alert" style="background:var(--secondary-soft);color:#8a7a00;">
                <strong>Demo mode</strong> (email sending is off): your verification code is
                <strong style="letter-spacing:3px;font-size:16px;">@demoCode</strong>
            </div>
        }

        @if (TempData["Info"] is string info)
        {
            <div class="alert alert-success">@info</div>
        }
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="@(ViewData.ModelState.ErrorCount > 0 ? "" : "display:none")"></div>

        <form asp-action="Verify" method="post">
            <div class="mb-3">
                <label class="form-label" asp-for="Code"></label>
                <input class="form-control" asp-for="Code" placeholder="6-digit code" style="letter-spacing:6px;text-align:center;font-size:20px;" autofocus />
                <span asp-validation-for="Code" class="text-validation"></span>
            </div>
            <button type="submit" class="btn btn-brand w-100">Verify</button>
        </form>

        <form asp-action="Resend" method="post" class="text-center mt-3">
            <button type="submit" class="btn" style="background:none;color:var(--primary);font-size:14px;">Didn't get it? Resend code</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}