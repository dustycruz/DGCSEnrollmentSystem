@* File: EnrollmentSystem.UI/Views/Apply/SetPassword.cshtml *@
@model SetPasswordViewModel
@{
    ViewData["Title"] = "Set Password";
    Layout = "_Layout";
}
<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo"><img src="/images/logo.png" alt="DGCS" /></div>
        <div class="auth-title">Create Your Password</div>
        <div class="auth-sub">Step 3 — Secure your applicant account</div>

        <div class="steps">
            <div class="step done"><span class="dot">✓</span> Email</div>
            <div class="step done"><span class="dot">✓</span> Verify</div>
            <div class="step active"><span class="dot">3</span> Password</div>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="@(ViewData.ModelState.ErrorCount > 0 ? "" : "display:none")"></div>

        <form asp-action="SetPassword" method="post">
            <div class="mb-3">
                <label class="form-label" asp-for="Password"></label>
                <input class="form-control" asp-for="Password" type="password" placeholder="At least 6 characters" autofocus />
                <span asp-validation-for="Password" class="text-validation"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="ConfirmPassword"></label>
                <input class="form-control" asp-for="ConfirmPassword" type="password" placeholder="Re-enter password" />
                <span asp-validation-for="ConfirmPassword" class="text-validation"></span>
            </div>
            <button type="submit" class="btn btn-brand w-100">Create Account</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}