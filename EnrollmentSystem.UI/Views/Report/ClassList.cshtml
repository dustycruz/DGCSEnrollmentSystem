@* File: EnrollmentSystem.UI/Views/Report/ClassList.cshtml *@
@model IEnumerable<EnrollmentSystem.BLL.DTOs.ClassListRowDto>
@{
    ViewData["Title"] = "Class List";
    var sections = ViewBag.Sections as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    var sectionId = ViewBag.SectionId as int?;
}
<h1 class="page-title">Class List</h1>
<div class="content-card no-print">
    <form method="get" style="display:flex;gap:8px;">
        <select name="sectionId" class="form-select" style="max-width:340px;" asp-items="sections"><option value="">— Select section —</option></select>
        <button class="btn btn-brand">View</button>
    </form>
</div>
@if (Model.Any())
{
    <div class="content-card no-print" style="display:flex;justify-content:flex-end;">
        <button type="button" class="btn btn-ink" onclick="window.print()">🖨 Print / Save as PDF</button>
    </div>
    <div class="content-card">
        <div class="print-header">
            <img src="~/images/logo.png" alt="DGCS" onerror="this.style.display='none'" />
            <div>
                <h2>Divine Grace Center of Studies</h2>
                <p>47 General Avenue, GSIS Village, Tandang Sora, Quezon City &middot; School ID 482683</p>
                <p>Tel (02) 7901-1644 &middot; (0922) 899-9437 &middot; Class List (@Model.Count() students)</p>
            </div>
        </div>
        <table class="table">
            <thead><tr><th>#</th><th>Student No.</th><th>Name</th><th>Gender</th><th>Status</th><th class="no-print"></th></tr></thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr data-href="@Url.Action("StudentDetails", "Enrollment", new { id = r.StudentId, sectionId = sectionId })">
                        <td>@r.Number</td>
                        <td>@r.StudentNumber</td>
                        <td>@r.FullName</td>
                        <td>@r.Gender</td>
                        <td>@r.Status</td>
                        <td class="no-print" style="text-align:right;color:var(--muted);"><i data-lucide="chevron-right"></i></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>if (window.lucide) lucide.createIcons();</script>
}