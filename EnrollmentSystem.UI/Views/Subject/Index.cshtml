@* File: EnrollmentSystem.UI/Views/Subject/Index.cshtml *@
@model IEnumerable<Subject>
@{
    ViewData["Title"] = "Subjects";
}
<h1 class="page-title">Subjects</h1>
<p class="page-subtitle">Manage subjects offered.</p>
@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
<a class="btn btn-brand" asp-action="Create" style="margin-bottom:14px;"><i data-lucide="plus"></i> New Subject</a>
<div class="content-card">
    <table class="table">
        <thead><tr><th>Name</th><th>Code</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td><strong>@s.Name</strong></td>
                    <td>@s.Code</td>
                    <td><form asp-action="Delete" method="post" onsubmit="return confirm('Delete this subject?');"><input type="hidden" name="id" value="@s.SubjectId" /><button class="btn btn-danger" style="padding:6px 12px;font-size:13px;">Delete</button></form></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="3" style="text-align:center;color:var(--muted)">No subjects.</td></tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
    <script>if (window.lucide) lucide.createIcons();</script>
}