<h3><i data-lucide="gavel"></i> Review Decision</h3>
<p>Current status: <span class="badge-status @(Model.Status is "Approved" or "Enrolled" ? "badge-approved" : Model.Status == "Rejected" ? "badge-rejected" : "badge-pending")">@Model.Status</span></p>
@if (Model.Status == ApplicationStatuses.Enrolled)
{
    <p style="color:var(--muted);">This application is enrolled and locked. No further status changes are allowed.</p>
}
else
{
    <form asp-action="SetStatus" method="post">
        <input type="hidden" name="id" value="@Model.ApplicationId" />
        <label class="form-label">Remarks (visible to applicant)</label>
        <textarea name="remarks" class="form-control" rows="3">@Model.Remarks</textarea>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;">
            <button name="status" value="@ApplicationStatuses.UnderReview" class="btn btn-outline-brand" style="flex:1;">Under Review</button>
            <button name="status" value="@ApplicationStatuses.AdditionalRequirements" class="btn btn-accent" style="flex:1;">Request Docs</button>
            <button name="status" value="@ApplicationStatuses.Approved" class="btn btn-success" style="flex:1;">Approve</button>
            <button name="status" value="@ApplicationStatuses.Rejected" class="btn btn-danger" style="flex:1;">Reject</button>
        </div>
    </form>
}