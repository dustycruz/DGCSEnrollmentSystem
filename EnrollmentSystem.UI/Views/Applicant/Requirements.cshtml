@* File: EnrollmentSystem.UI/Views/Applicant/Requirements.cshtml *@
@model ApplicantPortalViewModel
@{
    ViewData["Title"] = "Requirements";
    var uploaded = Model.UploadedDocuments.ToList();
}
<h1 class="page-title">Admission Requirements</h1>
<p class="page-subtitle">Upload a clear photo or PDF of each document (max 5 MB).</p>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="content-card">
    @foreach (var doc in Model.RequiredDocuments)
    {
        var files = uploaded.Where(u => u.DocumentId == doc.DocumentId).ToList();
        <div class="req-row">
            <div>
                <strong>@doc.Name</strong>
                @if (files.Any())
                {
                    <span class="badge-status badge-approved" style="margin-left:8px;">@files.Count uploaded</span>
                    foreach (var f in files)
                    {
                        <a href="@f.Url" target="_blank" style="margin-left:8px;font-size:13px;">View</a>
                    }
                }
                else
                {
                    <span class="badge-status badge-pending" style="margin-left:8px;">Not uploaded</span>
                }
            </div>
            <form asp-action="UploadRequirement" method="post" enctype="multipart/form-data" class="req-upload">
                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                <input type="file" name="file" class="form-control" style="max-width:280px;" required />
                <button type="submit" class="btn btn-brand">Upload</button>
            </form>
        </div>
    }
</div>

<a class="btn btn-brand" asp-action="Payment">Continue to Payment</a>
<a class="btn btn-outline-brand" asp-action="Index">Back to Overview</a>