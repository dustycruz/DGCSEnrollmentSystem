@* File: EnrollmentSystem.UI/Views/Enrollment/Manage.cshtml *@
@model EnrollmentManageViewModel
@{
    ViewData["Title"] = "Manage Enrollment";
}
<h1 class="page-title">Enrollment — @Model.SectionName</h1>
@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="content-card">
    <h3><i data-lucide="user-plus"></i> Add Student</h3>
    <form asp-action="Enroll" method="post" style="display:flex;gap:8px;align-items:center;">
        <input type="hidden" name="sectionId" value="@Model.SectionId" />
        <select name="studentId" class="form-select" style="max-width:400px;" required asp-items="Model.Students"><option value="">— Select student —</option></select>
        <button type="submit" class="btn btn-success">Enroll</button>
    </form>
</div>

<div class="content-card">
    <h3><i data-lucide="users"></i> Enrolled Students</h3>
    @if (Model.Enrollments.Any())
    {
        <table class="table">
            <thead><tr><th>Student No.</th><th>Name</th><th>Status</th><th></th><th></th></tr></thead>
            <tbody>
                @foreach (var e in Model.Enrollments)
                {
                    <tr data-href="@Url.Action("StudentDetails", new { id = e.StudentId, sectionId = Model.SectionId })">
                        <td>@e.Student.StudentNumber</td>
                        <td>@e.Student.LastName, @e.Student.FirstName</td>
                        <td><span class="badge-status @(e.Status == "Enrolled" ? "badge-approved" : "badge-pending")">@e.Status</span></td>
                        <td style="white-space:nowrap;">
                            <form asp-action="Remove" method="post" style="display:inline;" onsubmit="return confirm('Remove this student?');"><input type="hidden" name="enrollmentId" value="@e.EnrollmentId" /><input type="hidden" name="sectionId" value="@Model.SectionId" /><button class="btn btn-danger" style="padding:4px 10px;font-size:12px;">Remove</button></form>
                        </td>
                        <td style="text-align:right;color:var(--muted);"><i data-lucide="chevron-right"></i></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:var(--muted)">No students enrolled yet.</p>
    }
</div>
<a class="btn btn-outline-brand" asp-controller="Section" asp-action="Index">Back to Sections</a>
@section Scripts {
    <script>if (window.lucide) lucide.createIcons();</script>
}