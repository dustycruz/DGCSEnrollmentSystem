@* File: EnrollmentSystem.UI/Views/Shared/_Layout.cshtml *@
@{
    var isAuthed = User.Identity?.IsAuthenticated ?? false;
    var role = User.GetPrimaryRole() ?? "";
    string ActiveIf(string ctrl) =>
        string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), ctrl, StringComparison.OrdinalIgnoreCase)
            ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DGCS Enrollment</title>
    <link rel="icon" href="/images/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (isAuthed)
    {
        <div class="app-shell">
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <img src="/images/logo.png" alt="DGCS" />
                    <div>
                        <div class="title">DGCS</div>
                        <div class="subtitle">Enrollment System</div>
                    </div>
                </div>

                <div class="user-card">
                    <div class="avatar">@User.GetInitials()</div>
                    <div>
                        <div class="name">@User.GetDisplayName()</div>
                        <div class="role">@role</div>
                    </div>
                </div>

                <nav>
                    <div class="nav-group-label">Main Menu</div>
                    <div class="nav-group-label">Management</div>
                    <a class="nav-link-item @ActiveIf("Admission")" asp-controller="Admission" asp-action="Index">
                        <i data-lucide="inbox"></i> Admissions
                    </a>
                    <a class="nav-link-item @ActiveIf("Home")" asp-controller="Home" asp-action="Dashboard">
                        <i data-lucide="layout-dashboard"></i> Dashboard
                    </a>

                    @if (User.IsInRole("Applicant"))
                    {
                        <a class="nav-link-item @ActiveIf("Applicant")" asp-controller="Applicant" asp-action="Index">
                            <i data-lucide="file-text"></i> My Applications
                        </a>
                    }

                    @if (User.IsInRole("Student"))
                    {
                        <a class="nav-link-item @ActiveIf("Student")" asp-controller="Student" asp-action="Index">
                            <i data-lucide="graduation-cap"></i> My Portal
                        </a>
                    }

                    @if (User.IsInRole("Teacher"))
                    {
                        <a class="nav-link-item @ActiveIf("Teacher")" asp-controller="Teacher" asp-action="Index">
                            <i data-lucide="book-open"></i> My Classes
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-group-label">Management</div>
                        <a class="nav-link-item @ActiveIf("Enrollment")" asp-controller="Enrollment" asp-action="Pending">
                            <i data-lucide="clipboard-check"></i> Enrollment
                        </a>
                        <a class="nav-link-item @ActiveIf("Section")" asp-controller="Section" asp-action="Index">
                            <i data-lucide="school"></i> Sections
                        </a>
                        <a class="nav-link-item @ActiveIf("Subject")" asp-controller="Subject" asp-action="Index">
                            <i data-lucide="book"></i> Subjects
                        </a>
                        <a class="nav-link-item @ActiveIf("Announcement")" asp-controller="Announcement" asp-action="Index">
                            <i data-lucide="megaphone"></i> Announcements
                        </a>

                        <div class="nav-group-label">Administration</div>
                        <a class="nav-link-item @ActiveIf("Admin")" asp-controller="Admin" asp-action="Users">
                            <i data-lucide="users"></i> User Accounts
                        </a>
                        <a class="nav-link-item @ActiveIf("Report")" asp-controller="Report" asp-action="Index">
                            <i data-lucide="bar-chart-3"></i> Reports
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="sign-out" style="background:none;border:none;width:100%;text-align:left;">
                            <i data-lucide="log-out"></i> Sign Out
                        </button>
                    </form>
                </div>
            </aside>

            <main class="main-content">
                <div class="topbar">
                    <div class="topbar-title">@ViewData["Title"]</div>
                    <div class="topbar-actions">
                        @await Component.InvokeAsync("NotificationBell")
                    </div>
                </div>
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- Lucide icons (browser build) -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Render all <i data-lucide="..."> into real SVG icons
        if (window.lucide) { lucide.createIcons(); }
    </script>
</body>
</html>