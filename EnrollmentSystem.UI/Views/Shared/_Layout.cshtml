@* File: EnrollmentSystem.UI/Views/Shared/_Layout.cshtml *@
@{
    var isAuthed = User.Identity?.IsAuthenticated ?? false;
    var role = User.GetPrimaryRole() ?? "";

    string ActiveIf(string ctrl) =>
        string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), ctrl, StringComparison.OrdinalIgnoreCase)
            ? "active" : "";

    string ActiveAction(string ctrl, string act) =>
        string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), ctrl, StringComparison.OrdinalIgnoreCase)
        && string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), act, StringComparison.OrdinalIgnoreCase)
            ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DGCS Enrollment</title>
    <link rel="icon" href="/images/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (isAuthed)
    {
        <div class="app-shell">
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <img src="/images/logo.png" alt="DGCS" />
                    <div>
                        <div class="title">DGCS</div>
                        <div class="subtitle">Enrollment System</div>
                    </div>
                </div>

                <div class="user-card">
                    <div class="avatar">@User.GetInitials()</div>
                    <div>
                        <div class="name">@User.GetDisplayName()</div>
                        <div class="role">@role</div>
                    </div>
                </div>

                <nav>
                    <div class="nav-group-label">Main Menu</div>
                    <a class="nav-link-item @ActiveIf("Home")" asp-controller="Home" asp-action="Dashboard">
                        <i data-lucide="layout-dashboard"></i> Dashboard
                    </a>

                    @if (User.IsInRole("Applicant"))
                    {
                        <a class="nav-link-item @ActiveIf("Applicant")" asp-controller="Applicant" asp-action="Index">
                            <i data-lucide="file-text"></i> My Applications
                        </a>
                    }

                    @if (User.IsInRole("Student"))
                    {
                        <a class="nav-link-item @ActiveAction("Student", "Index")" asp-controller="Student" asp-action="Index"><i data-lucide="graduation-cap"></i> My Portal</a>
                        <a class="nav-link-item @ActiveAction("Student", "Profile")" asp-controller="Student" asp-action="Profile"><i data-lucide="user"></i> My Profile</a>
                        <a class="nav-link-item @ActiveAction("Student", "Subjects")" asp-controller="Student" asp-action="Subjects"><i data-lucide="book"></i> My Subjects</a>
                        <a class="nav-link-item @ActiveAction("Student", "Schedule")" asp-controller="Student" asp-action="Schedule"><i data-lucide="clock"></i> Class Schedule</a>
                        <a class="nav-link-item @ActiveAction("Student", "Calendar")" asp-controller="Student" asp-action="Calendar"><i data-lucide="calendar"></i> Calendar</a>
                        <a class="nav-link-item @ActiveAction("Student", "Grades")" asp-controller="Student" asp-action="Grades"><i data-lucide="bar-chart-3"></i> My Grades</a>
                        <a class="nav-link-item @ActiveAction("Student", "Payments")" asp-controller="Student" asp-action="Payments"><i data-lucide="wallet"></i> Payments</a>
                        <a class="nav-link-item @ActiveAction("Student", "Announcements")" asp-controller="Student" asp-action="Announcements"><i data-lucide="megaphone"></i> Announcements</a>
                    }

                    @if (User.IsInRole("Teacher"))
                    {
                        <a class="nav-link-item @ActiveAction("Teacher", "Index")" asp-controller="Teacher" asp-action="Index"><i data-lucide="book-open"></i> My Classes</a>
                        <a class="nav-link-item @ActiveAction("Teacher", "Schedule")" asp-controller="Teacher" asp-action="Schedule"><i data-lucide="clock"></i> My Schedule</a>
                        <a class="nav-link-item @ActiveAction("Teacher", "Calendar")" asp-controller="Teacher" asp-action="Calendar"><i data-lucide="calendar"></i> Calendar</a>
                        <a class="nav-link-item @ActiveAction("Teacher", "Advisory")" asp-controller="Teacher" asp-action="Advisory"><i data-lucide="user-check"></i> My Advisory</a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-group-label">Management</div>
                        <a class="nav-link-item @ActiveIf("Admission")" asp-controller="Admission" asp-action="Index"><i data-lucide="inbox"></i> Admissions</a>
                        <a class="nav-link-item @ActiveIf("Section")" asp-controller="Section" asp-action="Index">
                            <i data-lucide="layout-grid"></i> Classes
                        </a>
                        <a class="nav-link-item @ActiveIf("Subject")" asp-controller="Subject" asp-action="Index"><i data-lucide="book"></i> Subjects</a>
                        <a class="nav-link-item @ActiveIf("Faculty")" asp-controller="Faculty" asp-action="Index"><i data-lucide="user-round"></i> Teachers</a>
                        <a class="nav-link-item @ActiveIf("Payment")" asp-controller="Payment" asp-action="Index"><i data-lucide="wallet"></i> Payments</a>
                        <a class="nav-link-item @ActiveIf("Announcement")" asp-controller="Announcement" asp-action="Index"><i data-lucide="megaphone"></i> Announcements</a>

                        <div class="nav-group-label">Administration</div>
                        <a class="nav-link-item @ActiveAction("Admin", "Users")" asp-controller="Admin" asp-action="Users">
                            <i data-lucide="users"></i> User Accounts
                        </a>
                        <a class="nav-link-item @ActiveAction("Admin", "Calendar")" asp-controller="Admin" asp-action="Calendar">
                            <i data-lucide="calendar"></i> Calendar
                        </a>
                        <a class="nav-link-item @ActiveIf("Report")" asp-controller="Report" asp-action="Index">
                            <i data-lucide="bar-chart-3"></i> Reports
                        </a>
                        <a class="nav-link-item @ActiveIf("Audit")" asp-controller="Audit" asp-action="Index">
                            <i data-lucide="scroll-text"></i> Audit Log
                        </a>
                    }

                    <div class="nav-group-label">Account</div>
                    <a class="nav-link-item @ActiveIf("Settings")" asp-controller="Settings" asp-action="Index">
                        <i data-lucide="settings"></i> Settings
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="sign-out" style="background:none;border:none;width:100%;text-align:left;">
                            <i data-lucide="log-out"></i> Sign Out
                        </button>
                    </form>
                </div>
            </aside>

            <main class="main-content">
                <div class="topbar">
                    <div class="topbar-title">@ViewData["Title"]</div>
                    <div class="topbar-actions">
                        @await Component.InvokeAsync("NotificationBell")
                    </div>
                </div>
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        if (window.lucide) { lucide.createIcons(); }
    </script>
</body>
</html>