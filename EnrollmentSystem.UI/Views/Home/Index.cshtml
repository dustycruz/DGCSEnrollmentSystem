@* File: EnrollmentSystem.UI/Views/Home/Index.cshtml *@
@model IEnumerable<Announcement>
@{
    ViewData["Title"] = "Home";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Divine Grace Center of Studies — Enrollment</title>
    <link rel="icon" href="/images/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="public-header">
        <div class="public-nav">
            <div class="public-brand">
                <img src="/images/logo.png" alt="DGCS" />
                <div>
                    <div class="n1">Divine Grace Center of Studies</div>
                    <div class="n2">Quezon City · Enrollment System</div>
                </div>
            </div>
            <nav class="public-links">
                <a href="#schedule">Schedule</a>
                <a href="#announcements">Announcements</a>
                <a class="btn btn-outline-brand" asp-controller="Account" asp-action="Login">Sign In</a>
                <a class="btn btn-accent" asp-controller="Apply" asp-action="Index">Apply Now</a>
            </nav>
        </div>
    </header>

    <!-- Text-only hero (no photo) -->
    <section class="hero2">
        <div class="hero2-inner hero2-centered">
            <span class="hero2-badge">Enrollment Open · S.Y. 2026–2027</span>
            <h1>Your journey starts at <span>Divine Grace Center of Studies</span></h1>
            <p class="hero2-tag">Nurturing the heart, mind, body &amp; soul.</p>
            <p>Apply online, upload your requirements, and track your admission status from start to finish — no lines, no hassle.</p>
            <div class="hero2-cta">
                <a class="btn btn-accent" asp-controller="Apply" asp-action="Index">Apply Now</a>
                <a class="btn btn-outline-ink" asp-controller="Account" asp-action="Login">Sign In</a>
            </div>
        </div>
    </section>

    <!-- Schedule -->
    <section class="public-section" id="schedule">
        <div class="panel-card panel-lg">
            <div class="panel-head">Enrollment Schedule · S.Y. 2026–2027</div>
            <div class="panel-body">
                <div class="sched-row"><span class="lbl">Online Application</span><span class="val">June 1 – July 15, 2026</span></div>
                <div class="sched-row"><span class="lbl">Document Verification</span><span class="val">June 5 – July 20, 2026</span></div>
                <div class="sched-row"><span class="lbl">Enrollment Confirmation</span><span class="val">July 1 – July 31, 2026</span></div>
                <div class="sched-row"><span class="lbl">Start of Classes</span><span class="val">August 10, 2026</span></div>
            </div>
        </div>
    </section>

    <!-- Announcements -->
    <section class="public-section" id="announcements" style="background:#fff;border-top:1px solid var(--border);">
        <div class="panel-card panel-lg">
            <div class="panel-head ink">Announcements</div>
            <div class="panel-body">
                @if (Model.Any())
                {
                    foreach (var a in Model)
                    {
                        <div class="announce-item">
                            <div style="display:flex;justify-content:space-between;">
                                <span class="t">@a.Title</span>
                                <span class="d">@a.PostedDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="c">@a.Content</div>
                        </div>
                    }
                }
                else
                {
                    <div class="announce-empty">No announcements at this time.</div>
                }
            </div>
        </div>
    </section>

    <footer class="public-footer-rich">
        <div class="footer-cols">
            <div>
                <div class="footer-brand">
                    <img src="/images/logo.png" alt="DGCS" />
                    <div>
                        <div class="fn">Divine Grace Center of Studies</div>
                        <div style="color:#b7afdc;font-size:12px;">Quezon City</div>
                    </div>
                </div>
                <p>…developing students with mind, heart, body and soul.</p>
            </div>
            <div>
                <h4>Contact</h4>
                <p><i data-lucide="map-pin"></i> 47 General Avenue, GSIS Village, Tandang Sora, Quezon City</p>
                <p><i data-lucide="phone"></i> (02) 7901-1644</p>
                <p><i data-lucide="smartphone"></i> (0922) 899-9437</p>
                <p><i data-lucide="badge-check"></i> School ID No. 482683</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <p><a asp-controller="Apply" asp-action="Index">Apply for Admission</a></p>
                <p><a asp-controller="Account" asp-action="Login">Student / Teacher Sign In</a></p>
                <p><a href="#schedule">Enrollment Schedule</a></p>
                <p><a href="#announcements">Announcements</a></p>
            </div>
        </div>
        <div class="footer-bottom">© @DateTime.Now.Year Divine Grace Center of Studies · Web-Based Enrollment System</div>
    </footer>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>if (window.lucide) { lucide.createIcons(); }</script>
</body>
</html>