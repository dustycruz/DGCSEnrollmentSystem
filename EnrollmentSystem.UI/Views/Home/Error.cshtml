@* File: EnrollmentSystem.UI/Views/Home/Error.cshtml *@
@{
    Layout = null;
    ViewData["Title"] = "Something went wrong";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - DGCS Enrollment</title>
    <link rel="icon" href="/images/logo.png" />
    <style>
        body { margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
               font-family: 'Segoe UI', system-ui, Arial, sans-serif; background: #f3f4f6; color: #260b6a; }
        .box { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 40px 44px;
               text-align: center; max-width: 460px; box-shadow: 0 4px 16px rgba(16,24,40,.08); }
        .box img { height: 60px; margin-bottom: 12px; }
        h1 { font-size: 22px; margin: 0 0 8px; }
        p { color: #6b7280; margin: 0 0 22px; }
        .btn { background: #0194fe; color: #fff; text-decoration: none; padding: 11px 22px;
               border-radius: 10px; font-weight: 700; display: inline-block; }
    </style>
</head>
<body>
    <div class="box">
        <img src="/images/logo.png" alt="DGCS" onerror="this.style.display='none'" />
         <h1>Something went wrong</h1>
        <p>An unexpected error occurred while processing your request. Please try again, or head back to your dashboard.</p>
        @{
            var reason = Context.Request.Query["reason"].ToString();
        }
        @if (!string.IsNullOrWhiteSpace(reason))
        {
            <pre style="text-align:left;background:#f8f9fb;border:1px solid #e5e7eb;border-radius:8px;padding:12px;font-size:12px;color:#b42318;white-space:pre-wrap;word-break:break-word;margin:0 0 22px;">@reason</pre>
        }
        <a class="btn" href="/Account/Logout">Sign Out</a>
        <a class="btn" href="/" style="background:#260b6a;margin-left:8px;">Home</a>
    </div>
</body>
</html>