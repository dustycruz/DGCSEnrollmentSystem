@* File: EnrollmentSystem.UI/Views/Student/Grades.cshtml *@
@model EnrollmentSystem.BLL.DTOs.ReportCardDto
@{
    ViewData["Title"] = "My Grades";
}
<h1 class="page-title">My Grades</h1>
<p class="page-subtitle">Report card and quarterly averages.</p>

@if (Model is not null && Model.Lines.Any())
{
    <div class="content-card no-print" style="display:flex;justify-content:flex-end;">
        <button type="button" class="btn btn-accent" onclick="window.print()">🖨 Print Report Card</button>
    </div>
}

<div class="content-card">
    <div class="print-header">
        <img src="~/images/logo.png" alt="DGCS" onerror="this.style.display='none'" />
        <div>
            <h2>Divine Grace Center of Studies</h2>
            <p>47 General Avenue, GSIS Village, Tandang Sora, Quezon City &middot; School ID 482683</p>
            <p>Tel (02) 7901-1644 &middot; (0922) 899-9437 &middot; Report Card</p>
        </div>
    </div>

    @if (Model is not null && Model.Lines.Any())
    {
        <h3>@Model.FullName <span style="color:var(--muted);font-size:14px;">(@Model.StudentNumber)</span></h3>
        <table class="table">
            <thead><tr><th>Subject</th><th>Q1</th><th>Q2</th><th>Q3</th><th>Q4</th><th>Final</th></tr></thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td><strong>@line.Subject</strong></td>
                        <td>@(line.Q1?.ToString("0.##") ?? "-")</td>
                        <td>@(line.Q2?.ToString("0.##") ?? "-")</td>
                        <td>@(line.Q3?.ToString("0.##") ?? "-")</td>
                        <td>@(line.Q4?.ToString("0.##") ?? "-")</td>
                        <td><strong>@(line.Final?.ToString("0.##") ?? "-")</strong></td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="5" style="text-align:right;"><strong>General Average</strong></td>
                    <td><strong style="color:var(--primary);">@(Model.GeneralAverage?.ToString("0.##") ?? "-")</strong></td>
                </tr>
            </tfoot>
        </table>
        <div class="print-signatures">
            <div><div class="line">Adviser's Signature</div></div>
            <div><div class="line">Parent / Guardian's Signature</div></div>
        </div>
    }
    else
    {
        <p style="color:var(--muted)">No grades have been posted yet.</p>
    }
</div>