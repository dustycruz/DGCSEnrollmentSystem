@* File: EnrollmentSystem.UI/Views/Section/Index.cshtml *@
@model IEnumerable<Section>
@{
    ViewData["Title"] = "Sections";
}
<h1 class="page-title">Sections</h1>
<p class="page-subtitle">Manage class sections and their schedules.</p>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
<a class="btn btn-brand" asp-action="Create" style="margin-bottom:14px;"><i data-lucide="plus"></i> New Section</a>

<div class="content-card">
    <table class="table">
        <thead><tr><th>Section</th><th>Grade Level</th><th>School Year</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td><strong>@s.Name</strong></td>
                    <td>@(s.GradeLevel?.Name ?? "-")</td>
                    <td>@(s.SchoolYear?.Name ?? "-")</td>
                    <td><a class="btn btn-outline-brand" style="padding:6px 12px;font-size:13px;" asp-action="Details" asp-route-id="@s.SectionId">Manage</a></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="4" style="text-align:center;color:var(--muted)">No sections yet.</td></tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
    <script>if (window.lucide) lucide.createIcons();</script>
}